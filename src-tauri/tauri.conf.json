{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pyforge",
  "version": "0.2.0",
  "identifier": "com.tiantian.pyforge",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PyForge",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' http://127.0.0.1:*",
        "connect-src": "'self' http://127.0.0.1:* ws://127.0.0.1:* http://localhost:1420",
        "frame-src": "'self' http://127.0.0.1:*",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' http://127.0.0.1:*",
        "style-src": "'self' 'unsafe-inline' http://127.0.0.1:*",
        "img-src": "'self' http://127.0.0.1:* data: blob:",
        "font-src": "'self' http://127.0.0.1:* data:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/uv"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
